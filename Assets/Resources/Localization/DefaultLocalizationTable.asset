  m_Script: {fileID: 11500000, guid: 344bb76890d84e82b66f504eaa83e0c5, type: 3}
  m_Name: DefaultLocalizationTable
  m_EditorClassIdentifier: Assembly-CSharp::Breach.Localization.LocalizationTableAsset
  entries:
  - key: ui.result.success.title
    value: 
    enValue: Mission Success
    ruValue: "\u041C\u0438\u0441\u0441\u0438\u044F \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u0430"
  - key: ui.result.success.body
    value: 
    enValue: Hostage secured and extracted.
    ruValue: "\u0417\u0430\u043B\u043E\u0436\u043D\u0438\u043A \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D
      \u0438 \u044D\u0432\u0430\u043A\u0443\u0438\u0440\u043E\u0432\u0430\u043D."
  - key: ui.result.fail.title
    value: 
    enValue: Mission Failed
    ruValue: "\u041C\u0438\u0441\u0441\u0438\u044F \u043F\u0440\u043E\u0432\u0430\u043B\u0435\u043D\u0430"
  - key: ui.result.fail.body
    value: 
    enValue: Hostage or squad lost.
    ruValue: "\u041F\u043E\u0442\u0435\u0440\u044F\u043D \u0437\u0430\u043B\u043E\u0436\u043D\u0438\u043A
      \u0438\u043B\u0438 \u0432\u0435\u0441\u044C \u043E\u0442\u0440\u044F\u0434."
  - key: ui.result.hint.restart
    value: 
    enValue: Press Play again to restart the mission.
    ruValue: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 Play \u0437\u0430\u043D\u043E\u0432\u043E,
      \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u0437\u0430\u043F\u0443\u0441\u0442\u0438\u0442\u044C
      \u043C\u0438\u0441\u0441\u0438\u044E."
  - key: ui.warning.friendly_fire_risk
    value: 
    enValue: Friendly Fire Risk
    ruValue: "\u0420\u0438\u0441\u043A \u043E\u0433\u043D\u044F \u043F\u043E \u0441\u0432\u043E\u0438\u043C"
  - key: ui.alert.idle
    value: 
    enValue: Idle
    ruValue: "\u0421\u043F\u043E\u043A\u043E\u0435\u043D"
  - key: ui.alert.suspicious
    value: 
    enValue: Suspicious
    ruValue: "\u041F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u0438\u0435"
  - key: ui.alert.alert
    value: 
    enValue: Alert
    ruValue: "\u0422\u0440\u0435\u0432\u043E\u0433\u0430"
  - key: hud.scene
    value: 
    enValue: 'scene: {0}'
    ruValue: "\u0441\u0446\u0435\u043D\u0430: {0}"
  - key: hud.mission_state
    value: 
    enValue: 'mission_state: {0}'
    ruValue: "\u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435_\u043C\u0438\u0441\u0441\u0438\u0438:
      {0}"
  - key: hud.objectives
    value: 
    enValue: 'obj_infiltration: {0} | obj_hostage_freed: {1} | obj_hostage_extracted:
      {2}'
    ruValue: "\u0446\u0435\u043B\u0438_\u0438\u043D\u0444\u0438\u043B\u044C\u0442\u0440\u0430\u0446\u0438\u044F:
      {0} | \u0446\u0435\u043B\u0438_\u0437\u0430\u043B\u043E\u0436\u043D\u0438\u043A_\u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D:
      {1} | \u0446\u0435\u043B\u0438_\u0437\u0430\u043B\u043E\u0436\u043D\u0438\u043A_\u044D\u0432\u0430\u043A\u0443\u0438\u0440\u043E\u0432\u0430\u043D:
      {2}"
  - key: hud.fail_flags
    value: 
    enValue: 'fail_squad_alive: {0} | fail_hostage_alive: {1}'
    ruValue: "\u043F\u0440\u043E\u0432\u0430\u043B_\u043E\u0442\u0440\u044F\u0434_\u0436\u0438\u0432:
      {0} | \u043F\u0440\u043E\u0432\u0430\u043B_\u0437\u0430\u043B\u043E\u0436\u043D\u0438\u043A_\u0436\u0438\u0432:
      {1}"
  - key: hud.active_operative
    value: 
    enValue: 'active_operative: {0}'
    ruValue: "\u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0439_\u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u0438\u043A:
      {0}"
  - key: hud.controls
    value: 
    enValue: 'controls: WASD move | Tab switch | E free hostage | LMB shoot | RMB
      aim preview | F1 hide hud'
    ruValue: "\u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435: WASD
      \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 | Tab \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435
      | E \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u0442\u044C \u0437\u0430\u043B\u043E\u0436\u043D\u0438\u043A\u0430
      | \u041B\u041A\u041C \u0432\u044B\u0441\u0442\u0440\u0435\u043B | \u041F\u041A\u041C
      \u043B\u0438\u043D\u0438\u044F \u043F\u0440\u0438\u0446\u0435\u043B\u0430 |
      F1 \u0441\u043A\u0440\u044B\u0442\u044C hud"
