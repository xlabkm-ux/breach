<?xml version="1.0" encoding="utf-8"?>
<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements">
  <ui:VisualElement name="MissionUIRoot" style="flex-grow: 1; justify-content: flex-end; align-items: center; padding-bottom: 24px;">
    <ui:VisualElement name="ResultPanel" style="min-width: 320px; min-height: 120px; background-color: rgba(0,0,0,0.55); border-top-left-radius: 8px; border-top-right-radius: 8px; border-bottom-left-radius: 8px; border-bottom-right-radius: 8px; padding-left: 16px; padding-right: 16px; padding-top: 12px; padding-bottom: 12px;">
      <ui:Label name="ResultTitle" text="ui.result.title" />
      <ui:Label name="ResultBody" text="ui.result.body" />
    </ui:VisualElement>
  </ui:VisualElement>
</ui:UXML>